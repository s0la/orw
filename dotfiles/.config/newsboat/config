bind-key j down
bind-key k up
bind-key l open
bind-key h quit

color listnormal color19 default
color listfocus color81 color18
color listnormal_unread color81 default
color listfocus_unread color92 color18
color info color81 color18

highlight article ".*" default default

reload-time 1
refresh-on-startup  yes
browser qutebrowser

#notify-always yes
#notify-program "~/.orw/scripts/notify.sh"
#notify-format "New feed: %n"
